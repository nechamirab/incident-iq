# ── Backend (server/) ────────────────────────────────────────────────
# Port the Express API listens on.
PORT=4001

# development | production | test
NODE_ENV=development

# Origin allowed to call the API via CORS (the Vite dev server by default).
CORS_ORIGIN=http://localhost:5173

# AI provider selection: "mock" (deterministic, offline, no API key needed),
# "anthropic" (real analysis via the Anthropic API), or "openai" (real
# analysis via the OpenAI API). Leave as "mock" for local development unless
# you have an API key for one of the real providers.
AI_PROVIDER=mock

# Required only when AI_PROVIDER=anthropic. Never commit a real key.
# The key is read by the backend only and is never exposed to the frontend.
# If AI_PROVIDER=anthropic and this is missing, analysis requests fail with
# a clear 503 error explaining how to switch back to AI_PROVIDER=mock — the
# app itself still starts normally.
ANTHROPIC_API_KEY=

# Optional: which Anthropic model to use when AI_PROVIDER=anthropic.
# Defaults to claude-sonnet-5 if unset.
ANTHROPIC_MODEL=claude-sonnet-5

# Required only when AI_PROVIDER=openai. Never commit a real key. The key is
# read by the backend only and is never exposed to the frontend. If
# AI_PROVIDER=openai and this is missing, analysis requests fail with a
# clear 503 error explaining how to switch back to AI_PROVIDER=mock — the
# app itself still starts normally.
OPENAI_API_KEY=

# Optional: which OpenAI model to use when AI_PROVIDER=openai.
# Defaults to gpt-5.1 if unset.
OPENAI_MODEL=gpt-5.1

# When AI_PROVIDER=anthropic or AI_PROVIDER=openai but no matching API key
# is configured, the app never silently substitutes mock output. Set this
# to "true" only if you explicitly want that fallback (e.g. a demo
# environment without a key) -- when it happens, every AI result is clearly
# recorded as provider "mock" with a fallbackReason. Must be exactly "true"
# or "false".
ALLOW_MOCK_FALLBACK=false

# ── Frontend (Vite) ──────────────────────────────────────────────────
# Base URL the frontend uses to reach the backend API.
VITE_API_BASE_URL=http://localhost:4001
