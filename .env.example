# ── Backend (server/) ────────────────────────────────────────────────
# Port the Express API listens on.
PORT=4000

# development | production | test
NODE_ENV=development

# Origin allowed to call the API via CORS (the Vite dev server by default).
CORS_ORIGIN=http://localhost:5173

# AI provider selection: "mock" (no external calls) or "anthropic".
# Introduced in Stage 4 — safe to leave as "mock" for now.
AI_PROVIDER=mock

# Required only when AI_PROVIDER=anthropic. Never commit a real key.
# The key is read by the backend only and is never exposed to the frontend.
ANTHROPIC_API_KEY=

# ── Frontend (Vite) ──────────────────────────────────────────────────
# Base URL the frontend uses to reach the backend API.
VITE_API_BASE_URL=http://localhost:4000
