# ── Backend (server/) ────────────────────────────────────────────────
# Port the Express API listens on.
PORT=4001

# development | production | test
NODE_ENV=development

# Origin allowed to call the API via CORS (the Vite dev server by default).
CORS_ORIGIN=http://localhost:5173

# AI provider selection: "mock" (deterministic, offline, no API key needed)
# or "anthropic" (real analysis via the Anthropic API). Leave as "mock" for
# local development unless you have an Anthropic API key.
AI_PROVIDER=mock

# Required only when AI_PROVIDER=anthropic. Never commit a real key.
# The key is read by the backend only and is never exposed to the frontend.
# If AI_PROVIDER=anthropic and this is missing, analysis requests fail with
# a clear 503 error explaining how to switch back to AI_PROVIDER=mock — the
# app itself still starts normally.
ANTHROPIC_API_KEY=

# Optional: which Anthropic model to use when AI_PROVIDER=anthropic.
# Defaults to claude-sonnet-5 if unset.
ANTHROPIC_MODEL=claude-sonnet-5

# ── Frontend (Vite) ──────────────────────────────────────────────────
# Base URL the frontend uses to reach the backend API.
VITE_API_BASE_URL=http://localhost:4001
